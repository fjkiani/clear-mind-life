# ── Clear Mind Life Frontend — Environment Variables ─────────────────────────
# Copy to .env.local for local development.

# Backend API URL (FastAPI at port 8001 locally, or your Render URL in production)
NEXT_PUBLIC_API_URL=http://localhost:8001

# Governance API (same backend)
NEXT_PUBLIC_GOVERNANCE_API_URL=http://localhost:8001

# Clerk Auth (https://clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Stripe (https://stripe.com)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
